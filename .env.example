# Database
DATABASE_URL=postgresql://user:password@localhost:5432/airbnb_pricing

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...         # chat_id dell'amico (per sicurezza, solo lui può usare il bot)

# Beds24 API v2
# Impostala in Beds24 → Account Access → API Key 1 → API Key
BEDS24_API_KEY=...

# AirDNA (prezzi competitor)
AIRDNA_API_KEY=...

# App
APP_ENV=development          # development | production
DAILY_ANALYSIS_HOUR=8        # ora di invio proposta mattutina
AUTONOMY_THRESHOLD_PCT=5.0   # variazioni sotto questa % vengono applicate autonomamente
